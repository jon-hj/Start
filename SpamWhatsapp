class WhatsAppBot:
    def __init__(self):
        self.driver = None
        self.wait = None

    def normalize_number(self, number: str) -> str:
        return "".join(ch for ch in number if ch.isdigit())

    def check_invalid_number(self) -> bool:
        invalid_xpaths = [
            "//*[contains(text(),'número de teléfono no es válido')]",
            "//*[contains(text(),'phone number shared via url is invalid')]",
            "//*[contains(text(),'El número de teléfono compartido a través de la URL no es válido')]",
            "//*[contains(text(),'inválido')]",
        ]
        for xp in invalid_xpaths:
            try:
                if self.driver.find_elements(By.XPATH, xp):
                    return True
            except:
                pass
        return False

    def setup_driver(self):
        print("Configurando Chrome...")
        chrome_options = Options()

        chrome_options.add_argument("--start-maximized")
        chrome_options.add_argument("--disable-notifications")
        chrome_options.add_argument("--disable-blink-features=AutomationControlled")
        chrome_options.add_experimental_option("excludeSwitches", ["enable-automation"])
        chrome_options.add_experimental_option("useAutomationExtension", False)

        user_profile = os.path.join(os.path.expanduser("~"), "whatsapp_session")
        chrome_options.add_argument(f"user-data-dir={user_profile}")

        prefs = {
            "profile.default_content_setting_values.notifications": 2,
            "profile.default_content_setting_values.media_stream": 1,
        }
        chrome_options.add_experimental_option("prefs", prefs)

        self.driver = webdriver.Chrome(
            service=Service(ChromeDriverManager().install()),
            options=chrome_options,
        )

        self.driver.execute_script(
            "Object.defineProperty(navigator, 'webdriver', {get: () => undefined})"
        )
        self.wait = WebDriverWait(self.driver, 30)

        return self.driver

    def wait_for_login(self):
        print("\n" + "=" * 60)
        print("WHATSAPP WEB - Escanea el codigo QR con tu celular")
        print("=" * 60 + "\n")

        try:
            start_time = time.time()

            while time.time() - start_time < 120:
                try:
                    if self.driver.find_elements(By.XPATH, "//div[@id='pane-side']") or \
                       self.driver.find_elements(By.XPATH, "//div[@data-testid='chat-list']"):
                        print("WhatsApp Web cargado correctamente")
                        time.sleep(3)
                        return True

                    if self.driver.find_elements(By.XPATH, "//canvas"):
                        elapsed = int(time.time() - start_time)
                        if elapsed % 15 == 0:
                            print(f"Esperando escaneo de QR... ({elapsed}s/120s)")

                except:
                    pass

                time.sleep(2)

            print("Tiempo de espera agotado para QR")
            return False

        except Exception as e:
            print(f"Error esperando login: {e}")
            return False

    def wait_for_chat_ready(self):
        try:
            self.wait.until(
                EC.presence_of_element_located((By.XPATH, "//div[@id='pane-side']"))
            )
            print("Panel lateral cargado")
            time.sleep(2)
            

            self.wait.until(
                EC.presence_of_element_located((By.XPATH, "//footer//div[@contenteditable='true']"))
            )
            print("Chat listo para usar (composer encontrado)")
            time.sleep(2)
            return True
        except Exception as e:
            print(f"Error esperando chat: {e}")
            
            if self.check_invalid_number():
                print("WhatsApp indica que el número es inválido (URL phone inválido).")
                return False
            try:
                error_elements = self.driver.find_elements(By.XPATH, "//div[contains(text(),'error') or contains(text(),'Error')]")
                if error_elements:
                    print(f"Se encontró error: {error_elements[0].text[:100]}")
                    return False
            except:
                pass
            
            return False

    def attach_video_direct(self, video_path):
        print("Adjuntando video...")

        try:
            try:
                text_field = self.driver.find_element(By.XPATH, "//footer//div[@contenteditable='true']")
                text_field.click()
                print("Campo de texto clickeado")
                time.sleep(2)
            except:
                print("No se pudo hacer clic en campo de texto, continuando...")
            try:
                js_script = """
                    var inputs = document.querySelectorAll('input[type="file"]');
                    for (var i = 0; i < inputs.length; i++) {
                        inputs[i].style.cssText = `
                            display: block !important;
                            visibility: visible !important;
                            opacity: 1 !important;
                            position: fixed !important;
                            top: 50px !important;
                            left: 50px !important;
                            width: 300px !important;
                            height: 100px !important;
                            z-index: 999999 !important;
                        `;
                    }
                    return inputs.length;
                """

                num_inputs = self.driver.execute_script(js_script)
                print(f"Inputs file encontrados: {num_inputs}")
                time.sleep(2)
                file_input = self.driver.find_element(By.XPATH, "//input[@type='file']")
                file_input.send_keys(video_path)
                print("Video enviado al input file")
                time.sleep(3)

                return True

            except Exception as e1:
                print(f"Método 1 falló: {e1}")

                # Método 2: Usar botón adjuntar
                try:
                    attach_selectors = [
                        "//div[@title='Adjuntar']",
                        "//div[@title='Attach']",
                        "//span[@data-testid='attach-menu-plus']",
                        "//div[@aria-label='Adjuntar']",
                    ]

                    for selector in attach_selectors:
                        try:
                            attach_btn = self.wait.until(
                                EC.element_to_be_clickable((By.XPATH, selector))
                            )
                            attach_btn.click()
                            print(f"Botón adjuntar encontrado: {selector}")
                            time.sleep(2)
                            break
                        except:
                            continue


                    time.sleep(2)
                    file_input = self.wait.until(
                        EC.presence_of_element_located((By.XPATH, "//input[@type='file']"))
                    )

                    file_input.send_keys(video_path)
                    print("Video enviado (método 2)")
                    time.sleep(3)
                    return True

                except Exception as e2:
                    print(f"Método 2 falló: {e2}")
                    return False

        except Exception as e:
            print(f"Error adjuntando video: {e}")
            traceback.print_exc()
            return False

    def wait_for_video_preview(self):
        print("Esperando preview del video...")

        try:
            for i in range(30):
                try:
                    preview_elements = self.driver.find_elements(
                        By.XPATH,
                        "//video | "
                        "//div[contains(@class, 'video-thumb')] | "
                        "//div[contains(@class, 'preview')]",
                    )

                    if preview_elements:
                        print("Preview del video cargado")
                        time.sleep(3)
                        return True

                    if i % 5 == 0:
                        print(f"Esperando video... {i+1}/30 segundos")

                except:
                    pass

                time.sleep(1)

            print("No se detectó preview del video, continuando...")
            time.sleep(3)
            return True

        except Exception as e:
            print(f"Error esperando preview: {e}")
            time.sleep(5)
            return True

    def add_caption_to_video(self, message):
        print("Agregando mensaje al video...")

        try:
            time.sleep(3)

            caption_selectors = [
                "//div[@contenteditable='true' and @data-tab='11']",
                "//div[@contenteditable='true' and @placeholder='Añade un pie de foto']",
                "//div[@contenteditable='true' and @placeholder='Add a caption']",
                "//div[@contenteditable='true' and @spellcheck='true']",
                "//div[@contenteditable='true' and @data-tab='10']",
                "//div[@contenteditable='true']",
            ]

            caption_field = None

            for selector in caption_selectors:
                try:
                    elements = self.driver.find_elements(By.XPATH, selector)
                    for elem in elements:
                        try:
                            if elem.is_displayed() and elem.is_enabled():
                                caption_field = elem
                                print(f"Campo caption encontrado: {selector}")
                                break
                        except:
                            continue
                    if caption_field:
                        break
                except:
                    continue

            if not caption_field:
                print("No se encontró campo para caption del video")
                return False

            try:

                self.driver.execute_script("arguments[0].click();", caption_field)
                time.sleep(1)


                self.driver.execute_script("arguments[0].innerHTML = '';", caption_field)
                time.sleep(0.5)

                safe_message = message.replace("'", "\\'").replace('"', '\\"')
                
                js_script = f"""
                    var element = arguments[0];
                    var text = '{safe_message}';
                    
                    element.textContent = text;
                    
                    var inputEvent = new Event('input', {{ bubbles: true }});
                    var changeEvent = new Event('change', {{ bubbles: true }});
                    element.dispatchEvent(inputEvent);
                    element.dispatchEvent(changeEvent);
                    
                    return element.textContent.length;
                """
                
                text_length = self.driver.execute_script(js_script, caption_field)
                print(f"Mensaje escrito usando JavaScript: {text_length} caracteres")
                time.sleep(2)

                try:
                    text_content = self.driver.execute_script("return arguments[0].textContent || arguments[0].innerText;", caption_field)
                    if text_content and len(text_content.strip()) > 0:
                        print(f"Mensaje confirmado: {len(text_content)} caracteres")
                        if text_content[:20] in message:
                            print("Mensaje correcto verificado")
                    else:
                        print("No se pudo verificar texto, pero continuando...")
                except:
                    print("No se pudo verificar texto, continuando...")

                time.sleep(2)
                return True

            except Exception as e:
                print(f"Error escribiendo mensaje con JavaScript: {e}")
                

                try:
                    print("Intentando método alternativo (ASCII seguro)...")
                    
                    caption_field.click()
                    time.sleep(0.5)
                    
                    safe_message = message
                    # Remover caracteres problemáticos si existen
                    if "👉" in safe_message:
                        safe_message = safe_message.replace("👉", "->")
                    
                    for char in safe_message:
                        try:
                            caption_field.send_keys(char)
                            time.sleep(0.05)
                        except:
                            continue
                    
                    print(f"Mensaje escrito (método alternativo): {len(safe_message)} caracteres")
                    time.sleep(2)
                    return True
                    
                except Exception as e2:
                    print(f"Método alternativo también falló: {e2}")
                    return False

        except Exception as e:
            print(f"Error agregando caption: {e}")
            traceback.print_exc()
            return False

    def find_and_click_send_button(self):
        print("Buscando botón de enviar...")

        send_selectors = [
            "//span[@data-icon='send']",
            "//span[@data-testid='send']",
            "//button[@aria-label='Enviar']",
            "//button[@aria-label='Send']",
            "//div[@aria-label='Enviar']",
            "//div[@aria-label='Send']",
            "//button[@title='Enviar']",
            "//button[@title='Send']",
            "//div[@title='Enviar']",
            "//div[@title='Send']",
            "//button[contains(@class, 'send')]",
            "//div[contains(@class, 'send')]",
            "//span[contains(@class, 'send')]",
            "//div[@role='button' and @tabindex='0' and contains(@class, 'send')]",
            "//button[@role='button' and @tabindex='0']",
            "//footer//button",
            "//footer//div[@role='button']",
            "//div[contains(@class, 'footer')]//button",
            "//div[contains(@class, 'compose')]//button",
        ]

        for selector in send_selectors:
            try:
                print(f"Probando selector: {selector}")
                elements = self.driver.find_elements(By.XPATH, selector)

                for element in elements:
                    try:
                        if element.is_displayed():
                            print(f"Elemento encontrado y visible: {selector}")

                            try:
                                timestamp = int(time.time())
                                element.screenshot(f"send_button_{timestamp}.png")
                                print(f"Captura del botón guardada: send_button_{timestamp}.png")
                            except:
                                pass

                            try:
                                self.driver.execute_script("arguments[0].click();", element)
                                print("Clic exitoso con JavaScript")
                                return True
                            except:
                                try:
                                    actions = ActionChains(self.driver)
                                    actions.move_to_element(element).click().perform()
                                    print("Clic exitoso con ActionChains")
                                    return True
                                except:
                                    try:
                                        element.click()
                                        print("Clic exitoso directo")
                                        return True
                                    except Exception as e:
                                        print(f"Click directo falló: {e}")
                                        continue
                    except:
                        continue
            except:
                continue

        print("Intentando método de coordenadas para botón enviar...")
        return self.click_send_by_coordinates()

    def click_send_by_coordinates(self):
        try:
            window_size = self.driver.get_window_size()
            width = window_size["width"]
            height = window_size["height"]

            click_points = [
                (width - 80, height - 80),
                (width - 100, height - 100),
                (width - 60, height - 60),
            ]

            for x, y in click_points:
                try:
                    js_click = f"""
                        var event = new MouseEvent('click', {{
                            view: window,
                            bubbles: true,
                            cancelable: true,
                            clientX: {x},
                            clientY: {y}
                        }});
                        var element = document.elementFromPoint({x}, {y});
                        if (element) {{
                            element.dispatchEvent(event);
                            return element.tagName + ' ' + (element.className || '');
                        }}
                        return null;
                    """
                    result = self.driver.execute_script(js_click)
                    if result:
                        print(f"Clic en coordenadas ({x}, {y}) - Elemento: {result}")
                        time.sleep(1)
                        return True
                except:
                    continue

            print("Intentando con ENTER...")
            actions = ActionChains(self.driver)
            actions.send_keys(Keys.ENTER).perform()
            print("ENTER presionado")
            return True

        except Exception as e:
            print(f"Error en método de coordenadas: {e}")
            return False

    def send_video_with_message(self):
        print("Enviando video con mensaje...")

        try:
            time.sleep(2)

            try:
                timestamp = int(time.time())
                self.driver.save_screenshot(f"before_send_{timestamp}.png")
                print(f"Captura antes de enviar: before_send_{timestamp}.png")
            except:
                pass

            if not self.find_and_click_send_button():
                print("No se pudo encontrar ni hacer clic en el botón de enviar")
                return False

            print("Esperando 40 segundos después de enviar...")
            time.sleep(40)

            if self.verify_sent_message():
                print("VIDEO ENVIADO CON ÉXITO")
                return True
            else:
                print("Envío no verificado automáticamente")
                return True

        except Exception as e:
            print(f"Error enviando video: {e}")
            traceback.print_exc()
            return False

    def verify_sent_message(self):
        try:
            time.sleep(3)

            checks = self.driver.find_elements(
                By.XPATH,
                "//span[@data-testid='msg-dblcheck'] | "
                "//span[@data-testid='msg-check'] | "
                "//span[@data-icon='msg-dblcheck']",
            )

            if checks:
                print("Checks de envío visibles")
                return True

            sent_msgs = self.driver.find_elements(
                By.XPATH,
                "//div[contains(@class, 'message-out')] | "
                "//div[@data-id]",
            )

            if sent_msgs:
                print(f"{len(sent_msgs)} mensajes en salida")
                return True

            print("Asumiendo éxito después de tiempo de espera")
            return True

        except Exception as e:
            print(f"Error verificando envío: {e}")
            return False

    def send_to_number(self, number, video_path, message):
        print(f"\n" + "=" * 60)
        print(f"CONTACTO: {number}")
        print("=" * 60)

        try:
            # 1. Navegar al chat con más tiempo de espera
            print("1. Navegando al chat...")
            clean_number = self.normalize_number(number)
            
            # Usar URL sin parámetro de texto para evitar problemas
            self.driver.get(f"https://web.whatsapp.com/send?phone={clean_number}")
            time.sleep(10)  # Más tiempo para cargar
            
            # Verificar si la pantalla está en blanco
            try:
                page_state = self.driver.execute_script("return document.readyState;")
                print(f"Estado de la página: {page_state}")
                
                # Tomar captura para diagnóstico
                timestamp = int(time.time())
                self.driver.save_screenshot(f"chat_load_{timestamp}.png")
                print(f"Captura tomada: chat_load_{timestamp}.png")
            except:
                pass

            # 2. Esperar chat - con reintentos
            print("2. Esperando chat (con reintentos)...")
            max_retries = 3
            chat_ready = False
            
            for retry in range(max_retries):
                if self.wait_for_chat_ready():
                    chat_ready = True
                    break
                else:
                    print(f"Intento {retry + 1}/{max_retries} falló, reintentando...")
                    time.sleep(5)
                    # Intentar recargar
                    if retry < max_retries - 1:
                        self.driver.refresh()
                        time.sleep(8)
            
            if not chat_ready:
                print("No se pudo cargar el chat después de múltiples intentos")
                return False

            # 3. Adjuntar video
            print("3. Adjuntando video...")
            if not self.attach_video_direct(video_path):
                print("No se pudo adjuntar el video")
                return False

            # 4. Esperar preview
            print("4. Esperando preview del video...")
            if not self.wait_for_video_preview():
                print("No se detectó preview del video")

            # 5. Agregar mensaje
            print("5. Agregando mensaje al video...")
            if not self.add_caption_to_video(message):
                print("No se pudo agregar mensaje al video")
                return False

            # 6. Enviar
            print("6. Enviando video con mensaje...")
            if not self.send_video_with_message():
                print("No se pudo enviar el video")
                return False

            print(f"Video enviado exitosamente a {number}")
            return True

        except Exception as e:
            print(f"Error procesando {number}: {e}")
            traceback.print_exc()
            return False

    def run(self):
        print("\n" + "=" * 60)
        print("BOT WHATSAPP - ENVÍO DE VIDEOS CON MENSAJE")
        print("=" * 60)

        print(f"\nVideo: {VIDEO_PATH}")
        print(f"Tamaño: {os.path.getsize(VIDEO_PATH) / (1024*1024):.2f}MB")
        print(f"Contactos: {len(NUMBERS)}")

        self.setup_driver()

        try:
            print("\nCargando WhatsApp Web...")
            self.driver.get("https://web.whatsapp.com")

            if not self.wait_for_login():
                print("No se pudo iniciar sesión")
                self.driver.quit()
                return

            print("\n" + "=" * 60)
            print("SESIÓN INICIADA - COMIENZAN ENVÍOS")
            print("=" * 60)

            success_count = 0
            total = len(NUMBERS)

            for idx, number in enumerate(NUMBERS, 1):
                print(f"\n[{idx}/{total}] Procesando: {number}")

                for attempt in range(1, 4):
                    print(f"Intento {attempt}/3...")

                    if self.send_to_number(number, VIDEO_PATH, MESSAGE):
                        success_count += 1
                        print(f"Contacto {idx} COMPLETADO")
                        break
                    else:
                        if attempt < 3:
                            wait_time = random.randint(10, 15)
                            print(f"Esperando {wait_time}s antes de reintentar...")
                            time.sleep(wait_time)
                        else:
                            print(f"Contacto {idx} FALLÓ después de 3 intentos")

                if idx < total:
                    print(f"Esperando 40 segundos antes del siguiente contacto...")
                    for remaining in range(40, 0, -5):
                        print(f"   {remaining}s restantes...")
                        time.sleep(min(5, remaining))

            print("\n" + "=" * 60)
            print("RESULTADO FINAL")
            print("=" * 60)
            print(f"Éxitos: {success_count}/{total}")

            if success_count == total:
                print("TODOS LOS ENVÍOS EXITOSOS!")
            elif success_count > 0:
                print(f"Envío parcial: {success_count} de {total}")
            else:
                print("No se pudo enviar a ningún contacto")

            print("\nEsperando 40 segundos antes de cerrar...")
            for i in range(40, 0, -5):
                print(f"   {i}s restantes...")
                time.sleep(min(5, i))

        except KeyboardInterrupt:
            print("\n\nProceso interrumpido por el usuario")
        except Exception as e:
            print(f"\nERROR INESPERADO: {e}")
            traceback.print_exc()
        finally:
            print("\nCerrando navegador...")
            try:
                self.driver.quit()
            except:
                pass
            print("Proceso terminado")


if __name__ == "__main__":
    bot = WhatsAppBot()
    bot.run()
